{
    "name": "wsdltophp/bing",
    "description": "Package generated from __WSDL_URL__ using wsdltophp/packagegenerator",
    "require": {
        "php": ">=7.4",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-soap": "*",
        "wsdltophp/packagebase": "~5.0",
        "wsdltophp/wssecurity": "dev-master"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^9",
        "rector/rector": "^2"
    },
    "autoload": {
        "psr-4": {
            "": "./src/"
        }
    },  
    "config": {
        "disable-tls": true,
        "sort-packages": true
    }
}